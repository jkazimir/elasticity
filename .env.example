# Copy this file to .env and fill in your values.
# docker compose will automatically load .env from the project root.

# LLM API keys (at least one required to run orchestrations)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=http://localhost:11434/v1   # for local Ollama, etc.

# Host port to expose the web UI on (default: 8080)
# ELASTICITY_PORT=8080

# Directory containing your YAML orchestration config files (default: current directory)
# CONFIGS_DIR=/path/to/your/configs

# Writable directory for orchestrations that use file_write or shell tools (default: ./workspace)
# WORKSPACE_DIR=/path/to/workspace
